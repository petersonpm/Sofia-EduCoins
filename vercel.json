{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.ts"
    },
    {
      "source": "/((?!api|assets|favicon.svg|sw.js|manifest.webmanifest|registerSW.js|workbox-).*)",
      "destination": "index.html"
    }
  ]
}
